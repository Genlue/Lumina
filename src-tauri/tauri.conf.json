{
  "productName": "Lumina",
  "version": "1.0.0",
  "identifier": "com.lumina.album",
  "build": {
    "frontendDist": "../src/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "流光相册",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "icon": ["icons/icon.ico"],
    "resources": {
      "../src/renderer/**/*": "src/renderer/",
      "../README.md": "README.md",
      "../.gitignore": ".gitignore",
      "../Lumina.bat": "Lumina.bat",
      "Cargo.toml": "src-tauri/Cargo.toml",
      "Cargo.lock": "src-tauri/Cargo.lock",
      "src/**/*": "src-tauri/src/",
      "icons/**/*": "src-tauri/icons/",
      "build.rs": "src-tauri/build.rs",
      "tauri.conf.json": "src-tauri/tauri.conf.json"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": true
      }
    }
  }
}
